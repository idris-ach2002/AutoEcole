<form method="post" action="{{ path('app_candidat_delete', {'id': candidat.id}) }}" style="display:inline" data-confirm="Supprimer ce candidat et toutes ses inscriptions ?">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ candidat.id) }}">
    <button class="btn small danger">Supprimer</button>
</form>
