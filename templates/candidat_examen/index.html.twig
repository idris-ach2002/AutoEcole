{% extends 'base.html.twig' %}
{% block title %}Inscriptions{% endblock %}
{% block body %}
<div class="hero-card"><p class="eyebrow">Pipeline opérationnel</p><h1>Inscriptions</h1><p class="lead">Statuts, paiements d’examen, résultats et contrôles de progression.</p><div class="actions"><a class="btn primary" href="{{ path('app_candidat_examen_new') }}">+ Inscrire</a><a class="btn" href="{{ path('app_historique_examens') }}">Historique</a></div></div>
<section class="grid grid-4" style="margin-top:18px"><div class="metric-card"><strong>{{ statusStats.inscrit }}</strong><span>Inscrits</span></div><div class="metric-card"><strong>{{ statusStats['payé'] }}</strong><span>Payés</span></div><div class="metric-card"><strong>{{ statusStats['réussi'] }}</strong><span>Réussis</span></div><div class="metric-card"><strong>{{ statusStats['échoué'] }}</strong><span>Échoués</span></div></section>
<form class="filter-card filters" method="get"><div class="field"><label>Recherche</label><input name="q" value="{{ filters.q }}" placeholder="Nom ou email"></div><div class="field"><label>Statut</label><select name="status"><option value="">Tous</option>{% for s in ['inscrit','payé','réussi','échoué'] %}<option value="{{ s }}" {{ filters.status == s ? 'selected' }}>{{ s|capitalize }}</option>{% endfor %}</select></div><div class="field"><label>Type</label><select name="type"><option value="">Tous</option><option value="code" {{ filters.type == 'code' ? 'selected' }}>Code</option><option value="creneau" {{ filters.type == 'creneau' ? 'selected' }}>Créneau</option><option value="conduite" {{ filters.type == 'conduite' ? 'selected' }}>Conduite</option></select></div><div class="field"><label>Paiement examen</label><select name="payment"><option value="">Tous</option><option value="due" {{ filters.payment == 'due' ? 'selected' }}>Reste dû</option><option value="paid" {{ filters.payment == 'paid' ? 'selected' }}>Soldé</option></select></div><button class="btn primary">Filtrer</button></form>
<div class="table-card"><table><thead><tr><th>Candidat</th><th>Examen</th><th>Statut</th><th>Reste examen</th><th>Actions rapides</th></tr></thead><tbody>{% for inscription in candidat_examens %}<tr><td><a href="{{ path('app_candidat_show', {id: inscription.candidat.id}) }}"><strong>{{ inscription.candidat.nomComplet }}</strong></a><br><small style="color:var(--muted)">{{ inscription.candidat.email ?: '-' }}</small></td><td>{{ inscription.examen.typeLabel }}<br><small>{{ inscription.examen.datePassage|date('d/m/Y') }} - {{ inscription.examen.lieu ?: '-' }}</small></td><td><span class="badge {{ inscription.reussi ? 'success' : (inscription.echoue ? 'danger' : 'warning') }}">{{ inscription.statutLabel }}</span></td><td>{{ inscription.resteAPayer|number_format(0, ',', ' ') }} DZD</td><td><div class="actions"><a class="btn small" href="{{ path('app_candidat_examen_show', {id: inscription.id}) }}">Voir</a><a class="btn small warning" href="{{ path('app_candidat_examen_edit', {id: inscription.id}) }}">Modifier</a><form class="inline-form" method="post" action="{{ path('app_candidat_examen_update_statut', {id: inscription.id}) }}"><input type="hidden" name="_token" value="{{ csrf_token('statut' ~ inscription.id) }}"><select name="statut"><option value="inscrit">Inscrit</option><option value="payé">Payé</option><option value="réussi">Réussi</option><option value="échoué">Échoué</option></select><button class="btn small success">OK</button></form>{% if inscription.resteAPayer > 0 %}<form class="inline-form" method="post" action="{{ path('app_candidat_examen_payer', {id: inscription.id}) }}"><input type="hidden" name="_token" value="{{ csrf_token('payer-examen' ~ inscription.id) }}"><input type="number" min="0.01" step="0.01" name="montant" placeholder="Montant"><button class="btn small success">Payer</button></form>{% endif %}{{ include('candidat_examen/_delete_form.html.twig', {candidat_examen: inscription}) }}</div></td></tr>{% else %}<tr><td colspan="5">Aucune inscription trouvée.</td></tr>{% endfor %}</tbody></table></div>
{% endblock %}
