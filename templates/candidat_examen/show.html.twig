{% extends 'base.html.twig' %}{% block title %}Inscription{% endblock %}{% block body %}<div class="hero-card"><p class="eyebrow">Inscription</p><h1>{{ candidat_examen.candidat.nomComplet }}</h1><p class="lead">{{ candidat_examen.examen.typeLabel }} - {{ candidat_examen.examen.datePassage|date('d/m/Y') }}</p><div class="actions"><a class="btn" href="{{ path('app_candidat_examen_index') }}">Retour</a><a class="btn warning" href="{{ path('app_candidat_examen_edit', {id: candidat_examen.id}) }}">Modifier</a></div></div><section class="grid grid-4" style="margin-top:18px"><div class="metric-card"><strong>{{ candidat_examen.statutLabel }}</strong><span>Statut</span></div><div class="metric-card"><strong>{{ candidat_examen.resteAPayer|number_format(0, ',', ' ') }}</strong><span>DZD restants</span></div><div class="metric-card"><strong>{{ candidat_examen.examen.frais|number_format(0, ',', ' ') }}</strong><span>DZD frais</span></div><div class="metric-card"><strong>{{ candidat_examen.examen.past ? 'Passé' : 'À venir' }}</strong><span>État session</span></div></section>{% endblock %}
