<!doctype html>
<html lang="fr"><head><meta charset="utf-8"><title>Historique des examens</title><style>body{font-family:DejaVu Sans,Arial,sans-serif;font-size:11px;color:#111}h1{font-size:22px}table{width:100%;border-collapse:collapse;margin-top:16px}th,td{border:1px solid #ccc;padding:6px;text-align:left}th{background:#eef2ff}</style></head><body><h1>Historique des examens</h1><table><thead><tr><th>Candidat</th><th>Email</th><th>Téléphone</th><th>Examen</th><th>Date</th><th>Lieu</th><th>Frais</th><th>Reste</th><th>Statut</th></tr></thead><tbody>{% for ce in candidat_examens %}<tr><td>{{ ce.candidat.nomComplet }}</td><td>{{ ce.candidat.email }}</td><td>{{ ce.candidat.telephone }}</td><td>{{ ce.examen.typeLabel }}</td><td>{{ ce.examen.datePassage|date('d/m/Y') }}</td><td>{{ ce.examen.lieu }}</td><td>{{ ce.examen.frais|number_format(0, ',', ' ') }} DZD</td><td>{{ ce.resteAPayer|number_format(0, ',', ' ') }} DZD</td><td>{{ ce.statutLabel }}</td></tr>{% endfor %}</tbody></table></body></html>
