{% extends 'base.html.twig' %}
{% block title %}Examens{% endblock %}
{% block body %}
<div class="hero-card"><p class="eyebrow">Planification</p><h1>Examens</h1><p class="lead">Sessions de code, créneau et conduite, avec filtrage, export et suivi des inscriptions.</p><div class="actions"><a class="btn primary" href="{{ path('app_examen_new') }}">+ Planifier</a><a class="btn" href="{{ path('app_examen_export_csv', app.request.query.all()) }}">Export CSV</a></div></div>
<section class="grid grid-3" style="margin-top:18px"><div class="metric-card"><strong>{{ typeStats.code }}</strong><span>Code</span></div><div class="metric-card"><strong>{{ typeStats.creneau }}</strong><span>Créneau</span></div><div class="metric-card"><strong>{{ typeStats.conduite }}</strong><span>Conduite</span></div></section>
<form class="filter-card filters" method="get">
  <div class="field"><label>Type</label><select name="type"><option value="">Tous</option><option value="code" {{ filters.type == 'code' ? 'selected' }}>Code</option><option value="creneau" {{ filters.type == 'creneau' ? 'selected' }}>Créneau</option><option value="conduite" {{ filters.type == 'conduite' ? 'selected' }}>Conduite</option></select></div>
  <div class="field"><label>Lieu</label><input name="lieu" value="{{ filters.lieu }}" placeholder="Le Havre"></div>
  <div class="field"><label>Période</label><select name="period"><option value="">Toutes</option><option value="future" {{ filters.period == 'future' ? 'selected' }}>À venir</option><option value="past" {{ filters.period == 'past' ? 'selected' }}>Passées</option></select></div>
  <button class="btn primary">Filtrer</button>
</form>
<div class="table-card"><table><thead><tr><th>Type</th><th>Date</th><th>Lieu</th><th>Frais</th><th>Inscrits</th><th>État</th><th>Actions</th></tr></thead><tbody>
{% for examen in examens %}<tr>
<td><strong>{{ examen.typeLabel }}</strong></td><td>{{ examen.datePassage|date('d/m/Y') }}</td><td>{{ examen.lieu ?: '-' }}</td><td>{{ examen.frais|number_format(0, ',', ' ') }} DZD</td><td>{{ examen.inscritsCount }}</td><td><span class="badge {{ examen.past ? 'warning' : 'info' }}">{{ examen.past ? 'Passé' : 'À venir' }}</span></td><td><div class="actions"><a class="btn small" href="{{ path('app_examen_show', {id: examen.id}) }}">Voir</a><a class="btn small warning" href="{{ path('app_examen_edit', {id: examen.id}) }}">Modifier</a>{{ include('examen/_delete_form.html.twig') }}</div></td>
</tr>{% else %}<tr><td colspan="7">Aucun examen trouvé.</td></tr>{% endfor %}
</tbody></table></div>
{% endblock %}
